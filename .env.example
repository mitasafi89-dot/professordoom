# ProfessorDoom environment configuration
# Copy to .env and fill in. All values can also be set later via /admin.html.

# Gumloop session credentials (held server-side only, proxied to api.gumloop.com)
GUMLOOP_AUTH_KEY=          # x-auth-key header value (your Gumloop user id)
GUMLOOP_COOKIE=           # full session cookie string from a Gumloop request
GUMLOOP_GUMMIE_ID=        # which agent/gummie to drive

# Send-message endpoint (not present in the sample HAR — capture it from DevTools)
GUMLOOP_SEND_METHOD=POST
GUMLOOP_SEND_PATH=        # e.g. gummies/{gummieId}/start

# Optional: override the forwarded User-Agent
GUMLOOP_UA=

# Password that gates the admin dashboard. CHANGE THIS.
ADMIN_PASSWORD=changeme

# Server port.
PORT=3000
