# ProfessorDoom environment configuration
# Copy to .env and fill in. Most values can also be set via /admin (and then
# persist in the database, which becomes the source of truth on restart).

# Firebase refresh token (project agenthub-dev) — held server-side only.
# The server mints short-lived id_tokens from it. See PROTOCOL.md. Set via /admin.
GUMLOOP_REFRESH_TOKEN=

# Which agent/gummie to drive. Set via /admin.
GUMLOOP_GUMMIE_ID=

# Password that gates the admin dashboard at /admin. Can be changed from /admin.
ADMIN_PASSWORD=Create1#

# Database connection — set ONCE here; not editable from /admin.
# If set, config persists across restarts and conversations are logged.
DATABASE_URL=

# Platform keys — optional overrides (sensible defaults are built in).
# Normally identical across Gumloop accounts; editable from /admin if needed.
FIREBASE_API_KEY=
TURNSTILE_SITE_KEY=
HCAPTCHA_SITE_KEY=

# Server port. Can be changed from /admin (takes effect after a restart).
PORT=3000
