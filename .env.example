# ProfessorDoom environment configuration
# Copy to .env and fill in. Values can also be set later via the admin dashboard.

# Claude / Anthropic API key (recommended: a real Anthropic API key, x-api-key).
ANTHROPIC_API_KEY=

# Default model. Update as new Claude models ship.
DEFAULT_MODEL=claude-sonnet-4-20250514

# Max tokens per reply.
MAX_TOKENS=4096

# Password that gates the admin dashboard. CHANGE THIS.
ADMIN_PASSWORD=changeme

# Server port.
PORT=3000
