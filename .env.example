# ProfessorDoom environment configuration
# Copy to .env and fill in. Values can also be set via /admin.html.

# Firebase refresh token (project agenthub-dev) — held server-side only.
# The server mints short-lived id_tokens from it. See PROTOCOL.md.
GUMLOOP_REFRESH_TOKEN=

# Which agent/gummie to drive.
GUMLOOP_GUMMIE_ID=

# Password that gates the admin dashboard. CHANGE THIS.
ADMIN_PASSWORD=changeme

# Server port.
PORT=3000
